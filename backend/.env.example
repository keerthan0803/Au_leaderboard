# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/college_leaderboard

# JWT Secret key for authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Port
PORT=5000

# Admin Emails (comma-separated list)
# Example: admin1@example.com,admin2@example.com,admin3@example.com
ADMIN_EMAILS=keerthanpentam@gmail.com

# Google OAuth Credentials
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Frontend URL
FRONTEND_URL=http://localhost:3000

# API Keys for coding platforms (if needed in future)
# Note: GitHub uses web scraping, no API token needed
LEETCODE_API_KEY=your_leetcode_api_key_if_available
CODECHEF_API_KEY=your_codechef_api_key_here
HACKERRANK_API_KEY=your_hackerrank_api_key_here

# Node Environment
NODE_ENV=development
